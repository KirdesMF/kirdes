{
  "name": "remix-app-template",
  "private": true,
  "description": "",
  "license": "",
  "sideEffects": false,
  "scripts": {
    "postinstall": "remix setup node",
    "build": "build:css && build:uno && build:remix",
    "build:remix": "cross-env NODE_ENV=production remix build",
    "build:css": "postcss css --dir app/styles/",
    "build:uno": "unocss \"./app/**/*.{ts,tsx}\" -o ./app/styles/uno.css",
    "dev": "concurrently npm:dev:*",
    "dev:remix": "cross-env NODE_ENV=development remix dev",
    "dev:css": "postcss css --dir app/styles/ -w",
    "dev:uno": "unocss \"./app/**/*.{ts,tsx}\" -o ./app/styles/uno.css -w"
  },
  "dependencies": {
    "@notionhq/client": "^1.0.1",
    "@react-pdf/renderer": "^2.1.1",
    "@remix-run/react": "^1.2.3",
    "@remix-run/vercel": "^1.2.3",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "remix": "^1.2.3"
  },
  "devDependencies": {
    "@iconify-json/iconoir": "^1.1.1",
    "@iconify/react": "^3.1.4",
    "@remix-run/dev": "^1.2.3",
    "@remix-run/eslint-config": "^1.2.3",
    "@remix-run/serve": "^1.2.3",
    "@types/react": "^17.0.24",
    "@types/react-dom": "^17.0.9",
    "concurrently": "^7.0.0",
    "cross-env": "^7.0.3",
    "cssnano": "^5.1.3",
    "dotenv": "^16.0.0",
    "eslint": "^8.9.0",
    "postcss": "^8.4.8",
    "postcss-cli": "^9.1.0",
    "postcss-import": "^14.0.2",
    "tailwindcss": "^3.0.23",
    "typescript": "^4.5.5",
    "unocss": "^0.27.6"
  },
  "engines": {
    "node": ">=14"
  }
}
